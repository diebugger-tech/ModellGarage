# === ModellGarage — Environment-Vorlage ===
# Kopiere diese Datei zu .env und trage echte Werte ein.
# .env ist gitignored — niemals committen!

# --- App ---
APP_ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/modellgarage.db
MEDIA_DIR=./media

# --- eBay API (optional, Phase 3+) ---
# https://developer.ebay.com/ -> App anlegen -> Keys hier eintragen
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
# Sandbox zum Testen, Production erst wenn stabil
EBAY_ENV=sandbox
