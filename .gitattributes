# Windows/Podman: LF-Zeilenenden erzwingen — sonst brechen Shell-Skripte,
# Containerfile-CMD und der Python-Code im Linux-Container.
* text=auto eol=lf

*.py    text eol=lf
*.js    text eol=lf
*.svelte text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
Makefile text eol=lf
Containerfile text eol=lf

# Binärdateien nicht anfassen
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.xlsx  binary
*.db    binary
